# Streamlit Cloud Secrets Example
#
# 이 파일은 예시입니다. 실제 값은 GitHub에 올리지 마세요.
# Streamlit Cloud 배포 시 앱 설정 > Secrets 메뉴에서 아래 형식으로 입력:
#
# DB_URL = "mysql+pymysql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DBNAME>?charset=utf8mb4"
#
# 로컬 테스트 시에는 이 파일을 secrets.toml로 복사해서 실제 값 입력 (gitignore됨)

DB_URL = "mysql+pymysql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DBNAME>?charset=utf8mb4"
